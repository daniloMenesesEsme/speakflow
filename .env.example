APP_NAME=SpeakFlow
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# ─── Banco de Dados ───────────────────────────────────────────────────────────
# SpeakFlow usa PostgreSQL por padrão
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=speakflow
DB_USERNAME=postgres
DB_PASSWORD=

# ─── Sessão, Cache e Filas ────────────────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

# ─── JWT Authentication ───────────────────────────────────────────────────────
# Gerado automaticamente com: php artisan jwt:secret
JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=20160

# ─── OpenAI (Tutor Virtual + Whisper) ────────────────────────────────────────
# Necessário para: tutor IA real, correção gramatical avançada e transcrição de voz
# Sem esta chave, o app funciona em modo offline com respostas contextuais
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=300
OPENAI_ORGANIZATION=

# ─── Reconhecimento de Voz ────────────────────────────────────────────────────
# Driver de pronúncia: 'mock' (offline) ou 'azure'
SPEECH_DRIVER=mock

# Azure Speech Services (opcional — apenas se SPEECH_DRIVER=azure)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# ─── CORS ────────────────────────────────────────────────────────────────────
# Origens permitidas para o app mobile/web
FRONTEND_URL=http://localhost:3000

# ─── Mail ────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@speakflow.app"
MAIL_FROM_NAME="${APP_NAME}"
